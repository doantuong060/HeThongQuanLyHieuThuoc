@model IEnumerable<DuAnCuoiKy_QuanLyHieuThuoc.Models.ChiTietNhap>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SoLuong)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GiaNhap)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SoLo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HanSuDung)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ThanhTien)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaPhieuNhapNavigation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaThuocNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.SoLuong)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.GiaNhap)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SoLo)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HanSuDung)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ThanhTien)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaPhieuNhapNavigation.MaPhieuNhap)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MaThuocNavigation.MaThuoc)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MaCtn">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MaCtn">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MaCtn">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
